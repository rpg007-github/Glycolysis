function renderSA() {
  const container = document.getElementById('sa-questions');
  saData.forEach((item, i) => {
    const div = document.createElement('div');
    div.className = 'sa-item';
    div.innerHTML = `
      <div class="sa-q-num">QUESTION ${i+1} / ${saData.length}</div>
      <div class="sa-level-tag">${item.level}</div>
      <div class="sa-q-text">${item.q}</div>
      <textarea class="sa-textarea" id="sa-ta-${i}" placeholder="Write your answer here..."></textarea>
      <div><button class="sa-submit" onclick="gradeSA(${i})">Check My Answer</button></div>
      <div class="sa-result" id="sa-result-${i}">
        <div class="sa-score-row">
          <span class="sa-pct" id="sa-pct-${i}"></span>
          <div class="sa-bar-track"><div class="sa-bar-fill" id="sa-fill-${i}" style="width:0%"></div></div>
        </div>
        <div class="sa-tags" id="sa-tags-${i}"></div>
        <button class="sa-model-toggle" onclick="toggleModel(${i})">▾ Show Model Answer</button>
        <div class="sa-model" id="sa-model-${i}">${item.model}</div>
      </div>
    `;
    container.appendChild(div);
  });
}

function gradeSA(i) {
  const text = document.getElementById('sa-ta-' + i).value.toLowerCase();
  if (text.trim().length < 20) { alert('Please write a more complete answer before checking.'); return; }
  const item = saData[i];
  let totalScore = 0;
  let maxScore = 0;
  let tags = '';
  item.concepts.forEach(c => {
    maxScore += c.score;
    const hit = c.kw.some(kw => text.includes(kw));
    totalScore += hit ? c.score : 0;
    tags += `<span class="sa-tag ${hit ? 'hit' : 'miss'}">${hit ? '✓' : '✗'} ${c.label}</span>`;
  });
  const wordBonus = text.split(/\s+/).length > 80 ? 1 : 0;
  const pct = Math.min(100, Math.round((totalScore + wordBonus) / (maxScore + 1) * 100));
  const result = document.getElementById('sa-result-' + i);
  result.classList.add('show');
  document.getElementById('sa-pct-' + i).textContent = pct + '% match';
  document.getElementById('sa-tags-' + i).innerHTML = tags;
  const fill = document.getElementById('sa-fill-' + i);
  fill.style.background = pct >= 70 ? 'var(--accent)' : pct >= 45 ? 'var(--gold)' : 'var(--coral)';
  setTimeout(() => fill.style.width = pct + '%', 100);
}

function toggleModel(i) {
  document.getElementById('sa-model-' + i).classList.toggle('show');
}

