<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glycolysis &amp; Metabolism Gateway | Interactive Study Guide</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f1a14;
  --bg2: #162010;
  --bg3: #1d2b1a;
  --card: #1a2818;
  --card2: #213320;
  --border: #2e4a2b;
  --border2: #3d6438;
  --accent: #4ecb71;
  --accent2: #2ea84e;
  --accent3: #88e8a2;
  --gold: #f0c040;
  --coral: #f07060;
  --sky: #60b8e8;
  --lavender: #b090e0;
  --text: #e8f0e4;
  --text2: #a8c0a0;
  --text3: #6a8a62;
  --mono: 'JetBrains Mono', monospace;
  --serif: 'Playfair Display', Georgia, serif;
  --sans: 'DM Sans', sans-serif;
  --radius: 12px;
  --radius2: 20px;
  --shadow: 0 4px 24px rgba(0,0,0,0.4);
  --shadow2: 0 8px 40px rgba(0,0,0,0.6);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  font-size: 16px;
  line-height: 1.75;
  min-height: 100vh;
}

/* ---- BACKGROUND TEXTURE ---- */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 10% 20%, rgba(78,203,113,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 80% at 90% 80%, rgba(46,168,78,0.05) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

/* ---- LAYOUT ---- */
.page-wrap { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 0 24px 80px; }

/* ---- HERO ---- */
.hero {
  padding: 64px 0 40px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 40px;
}
.hero-eyebrow {
  font-family: var(--mono);
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 16px;
}
.hero h1 {
  font-family: var(--serif);
  font-size: clamp(2.2rem, 5vw, 3.6rem);
  font-weight: 700;
  line-height: 1.15;
  color: var(--text);
  margin-bottom: 20px;
}
.hero h1 em { color: var(--accent); font-style: italic; }
.hero-sub {
  font-size: 1.1rem;
  color: var(--text2);
  max-width: 680px;
  line-height: 1.7;
  margin-bottom: 28px;
}
.hero-meta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  align-items: center;
}
.series-badge {
  font-family: var(--mono);
  font-size: 0.7rem;
  padding: 5px 12px;
  border-radius: 50px;
  letter-spacing: 0.08em;
  font-weight: 600;
}
.badge-series { background: rgba(78,203,113,0.15); color: var(--accent); border: 1px solid rgba(78,203,113,0.3); }
.badge-unit { background: rgba(240,192,64,0.12); color: var(--gold); border: 1px solid rgba(240,192,64,0.25); }
.badge-next { background: rgba(96,184,232,0.1); color: var(--sky); border: 1px solid rgba(96,184,232,0.2); }

/* ---- LEVEL SWITCHER ---- */
.level-strip {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(15,26,20,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  padding: 12px 0;
  margin: 0 -24px 40px;
  padding-left: 24px;
  padding-right: 24px;
}
.level-strip-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.level-label {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--text3);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-right: 8px;
  white-space: nowrap;
}
.level-btn {
  font-family: var(--sans);
  font-size: 0.85rem;
  font-weight: 500;
  padding: 7px 20px;
  border-radius: 50px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.level-btn:hover { border-color: var(--accent2); color: var(--accent3); }
.level-btn.active {
  background: var(--accent);
  color: #0a1a0d;
  border-color: var(--accent);
  font-weight: 600;
}
.level-btn[data-level="hs"].active { background: var(--gold); border-color: var(--gold); color: #1a1000; }
.level-btn[data-level="college"].active { background: var(--sky); border-color: var(--sky); color: #061428; }
.level-indicator {
  margin-left: auto;
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--text3);
}
.level-indicator span { color: var(--text2); }

/* ---- TOC ---- */
.toc-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius2);
  padding: 28px 32px;
  margin-bottom: 48px;
}
.toc-card h3 {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  color: var(--text3);
  text-transform: uppercase;
  margin-bottom: 20px;
}
.toc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 8px;
}
.toc-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: var(--radius);
  border: 1px solid transparent;
  text-decoration: none;
  color: var(--text2);
  font-size: 0.88rem;
  transition: all 0.2s;
}
.toc-link:hover { background: var(--card2); border-color: var(--border); color: var(--text); }
.toc-num {
  font-family: var(--mono);
  font-size: 0.68rem;
  color: var(--accent);
  min-width: 22px;
}

/* ---- SECTION CARDS ---- */
.section-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius2);
  padding: 40px 44px;
  margin-bottom: 36px;
  position: relative;
  overflow: hidden;
}
.section-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent2), transparent);
}
.section-card h2 {
  font-family: var(--serif);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 24px;
  display: flex;
  align-items: baseline;
  gap: 14px;
}
.sec-num {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--accent);
  background: rgba(78,203,113,0.1);
  border: 1px solid rgba(78,203,113,0.2);
  padding: 3px 10px;
  border-radius: 4px;
  flex-shrink: 0;
}
.section-card h3 {
  font-family: var(--serif);
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--accent3);
  margin: 28px 0 12px;
}
.section-card p { color: var(--text2); margin-bottom: 16px; }
.section-card p:last-child { margin-bottom: 0; }

/* ---- LEVEL CONTENT ---- */
.level-content { display: none; }
.level-content.active { display: block; }

/* ---- CALLOUT BOXES ---- */
.callout {
  border-radius: var(--radius);
  padding: 18px 22px;
  margin: 20px 0;
  border-left: 3px solid;
}
.callout-label {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.callout.analogy { background: rgba(240,192,64,0.08); border-color: var(--gold); }
.callout.analogy .callout-label { color: var(--gold); }
.callout.analogy p { color: #d4b060; }
.callout.keyidea { background: rgba(78,203,113,0.08); border-color: var(--accent2); }
.callout.keyidea .callout-label { color: var(--accent); }
.callout.keyidea p { color: var(--text2); }
.callout.pitfall { background: rgba(240,112,96,0.08); border-color: var(--coral); }
.callout.pitfall .callout-label { color: var(--coral); }
.callout.pitfall p { color: #d09080; }
.callout.mnemonic { background: rgba(176,144,224,0.08); border-color: var(--lavender); }
.callout.mnemonic .callout-label { color: var(--lavender); }
.callout.mnemonic p { color: #c0a8e0; }
.callout.clinic { background: rgba(96,184,232,0.08); border-color: var(--sky); }
.callout.clinic .callout-label { color: var(--sky); }
.callout.clinic p { color: #80c0e0; }

/* ---- FORMULA BOX ---- */
.formula-box {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 16px 20px;
  margin: 20px 0;
  font-family: var(--mono);
  font-size: 0.9rem;
  color: var(--accent3);
  overflow-x: auto;
}
.formula-label {
  font-size: 0.65rem;
  color: var(--text3);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

/* ---- WORKED EXAMPLE ---- */
.worked-example {
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  padding: 22px 26px;
  margin: 22px 0;
}
.we-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}
.we-badge {
  font-family: var(--mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: rgba(96,184,232,0.15);
  color: var(--sky);
  border: 1px solid rgba(96,184,232,0.25);
  padding: 3px 10px;
  border-radius: 4px;
}
.we-title { font-weight: 600; color: var(--text); font-size: 0.95rem; }
.we-body p { color: var(--text2); margin-bottom: 10px; }
.we-body p:last-child { margin-bottom: 0; }
.we-step {
  display: flex;
  gap: 14px;
  margin-bottom: 10px;
  align-items: flex-start;
}
.we-step-num {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--sky);
  min-width: 22px;
  padding-top: 2px;
}

/* ---- INLINE PRACTICE Q ---- */
.practice-q {
  background: rgba(240,192,64,0.05);
  border: 1px solid rgba(240,192,64,0.2);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin: 22px 0;
}
.pq-header {
  font-family: var(--mono);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}
.pq-q { font-weight: 500; color: var(--text); margin-bottom: 14px; }
.pq-options { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
.pq-opt {
  background: var(--card2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 16px;
  cursor: pointer;
  color: var(--text2);
  font-size: 0.9rem;
  text-align: left;
  transition: all 0.15s;
  width: 100%;
}
.pq-opt:hover { border-color: var(--gold); color: var(--text); }
.pq-opt.correct { background: rgba(78,203,113,0.15); border-color: var(--accent); color: var(--accent3); }
.pq-opt.wrong { background: rgba(240,112,96,0.1); border-color: var(--coral); color: var(--coral); }
.pq-feedback {
  display: none;
  padding: 12px 16px;
  border-radius: 8px;
  font-size: 0.88rem;
  margin-top: 4px;
}
.pq-feedback.show { display: block; }
.pq-feedback.correct { background: rgba(78,203,113,0.1); color: var(--accent3); border: 1px solid rgba(78,203,113,0.2); }
.pq-feedback.wrong { background: rgba(240,112,96,0.08); color: #e09080; border: 1px solid rgba(240,112,96,0.2); }

/* ---- STEP TABLE ---- */
.step-table {
  width: 100%;
  border-collapse: collapse;
  margin: 20px 0;
  font-size: 0.875rem;
}
.step-table th {
  background: var(--bg2);
  color: var(--text3);
  font-family: var(--mono);
  font-size: 0.68rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 10px 14px;
  text-align: left;
  border-bottom: 1px solid var(--border2);
}
.step-table td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  color: var(--text2);
  vertical-align: top;
}
.step-table tr:hover td { background: rgba(255,255,255,0.02); }
.step-table code { font-family: var(--mono); font-size: 0.8rem; color: var(--accent3); }
.step-num-cell { font-family: var(--mono); color: var(--accent); font-weight: 600; font-size: 0.85rem; }
.enzyme-name { color: var(--sky); font-weight: 500; }
.energy-cell { font-family: var(--mono); font-size: 0.8rem; }
.energy-invest { color: var(--coral); }
.energy-harvest { color: var(--accent); }
.reg-cell { font-size: 0.8rem; color: var(--lavender); }

/* ---- QUIZ SECTION ---- */
.quiz-section {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius2);
  padding: 40px 44px;
  margin-bottom: 36px;
}
.quiz-section h2 {
  font-family: var(--serif);
  font-size: 1.8rem;
  color: var(--text);
  margin-bottom: 8px;
}
.quiz-section .section-sub { color: var(--text2); font-size: 0.95rem; margin-bottom: 28px; }
.quiz-item { margin-bottom: 28px; padding-bottom: 28px; border-bottom: 1px solid var(--border); }
.quiz-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.quiz-q-num { font-family: var(--mono); font-size: 0.68rem; color: var(--text3); letter-spacing: 0.1em; margin-bottom: 8px; }
.quiz-q-text { font-weight: 500; color: var(--text); margin-bottom: 14px; line-height: 1.6; }
.quiz-opts { display: flex; flex-direction: column; gap: 8px; }
.quiz-opt {
  background: var(--card2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 11px 18px;
  cursor: pointer;
  color: var(--text2);
  font-size: 0.9rem;
  text-align: left;
  transition: all 0.15s;
  width: 100%;
}
.quiz-opt:hover:not(:disabled) { border-color: var(--accent2); color: var(--text); }
.quiz-opt.correct { background: rgba(78,203,113,0.15); border-color: var(--accent); color: var(--accent3); }
.quiz-opt.wrong { background: rgba(240,112,96,0.1); border-color: var(--coral); color: var(--coral); }
.quiz-opt:disabled { cursor: default; }
.quiz-feedback { display: none; margin-top: 10px; padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; }
.quiz-feedback.show { display: block; }
.quiz-feedback.correct { background: rgba(78,203,113,0.1); color: var(--accent3); border: 1px solid rgba(78,203,113,0.15); }
.quiz-feedback.wrong { background: rgba(240,112,96,0.08); color: #d09080; border: 1px solid rgba(240,112,96,0.15); }
.quiz-score-bar {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin-top: 24px;
  display: none;
}
.quiz-score-bar.show { display: block; }
.score-label { font-family: var(--mono); font-size: 0.75rem; color: var(--text3); margin-bottom: 8px; }
.score-val { font-family: var(--serif); font-size: 2rem; color: var(--text); font-weight: 700; }
.score-track { height: 6px; background: var(--bg3); border-radius: 3px; margin-top: 12px; }
.score-fill { height: 100%; border-radius: 3px; background: var(--accent); transition: width 0.8s ease; }

/* ---- FLASHCARDS ---- */
.fc-section {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius2);
  padding: 40px 44px;
  margin-bottom: 36px;
}
.fc-section h2 { font-family: var(--serif); font-size: 1.8rem; color: var(--text); margin-bottom: 8px; }
.fc-sub { color: var(--text2); font-size: 0.95rem; margin-bottom: 24px; }
.fc-filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
.fc-filter {
  font-family: var(--mono);
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  padding: 5px 14px;
  border-radius: 50px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.15s;
}
.fc-filter:hover { border-color: var(--accent2); color: var(--accent3); }
.fc-filter.active { background: var(--accent2); color: #0a1a0d; border-color: var(--accent2); }
.fc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
.fc-card {
  height: 180px;
  perspective: 1000px;
  cursor: pointer;
}
.fc-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transform-style: preserve-3d;
  transition: transform 0.5s;
}
.fc-card.flipped .fc-inner { transform: rotateY(180deg); }
.fc-front, .fc-back {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  border-radius: var(--radius);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 20px;
}
.fc-front {
  background: var(--card2);
  border: 1px solid var(--border);
}
.fc-back {
  background: rgba(78,203,113,0.08);
  border: 1px solid rgba(78,203,113,0.25);
  transform: rotateY(180deg);
}
.fc-cat {
  font-family: var(--mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text3);
  margin-bottom: 10px;
}
.fc-front-text { font-weight: 500; color: var(--text); font-size: 0.9rem; line-height: 1.5; }
.fc-back-text { color: var(--accent3); font-size: 0.88rem; line-height: 1.6; }
.fc-hint { font-size: 0.7rem; color: var(--text3); margin-top: 12px; font-style: italic; }

/* ---- SHORT ANSWER ---- */
.sa-section {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius2);
  padding: 40px 44px;
  margin-bottom: 36px;
}
.sa-section h2 { font-family: var(--serif); font-size: 1.8rem; color: var(--text); margin-bottom: 8px; }
.sa-sub { color: var(--text2); font-size: 0.95rem; margin-bottom: 28px; }
.sa-item { margin-bottom: 32px; padding-bottom: 32px; border-bottom: 1px solid var(--border); }
.sa-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.sa-q-num { font-family: var(--mono); font-size: 0.68rem; color: var(--text3); letter-spacing: 0.1em; margin-bottom: 8px; }
.sa-q-text { font-weight: 500; color: var(--text); margin-bottom: 14px; line-height: 1.6; font-size: 1rem; }
.sa-level-tag { font-family: var(--mono); font-size: 0.62rem; color: var(--sky); background: rgba(96,184,232,0.1); border: 1px solid rgba(96,184,232,0.2); padding: 2px 8px; border-radius: 4px; display: inline-block; margin-bottom: 12px; }
.sa-textarea {
  width: 100%;
  min-height: 100px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 16px;
  color: var(--text);
  font-family: var(--sans);
  font-size: 0.9rem;
  line-height: 1.6;
  resize: vertical;
  outline: none;
  transition: border-color 0.2s;
}
.sa-textarea:focus { border-color: var(--accent2); }
.sa-submit {
  margin-top: 10px;
  padding: 9px 24px;
  background: var(--accent2);
  color: #051008;
  border: none;
  border-radius: 8px;
  font-family: var(--sans);
  font-size: 0.88rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}
.sa-submit:hover { background: var(--accent); }
.sa-result { display: none; margin-top: 16px; }
.sa-result.show { display: block; }
.sa-score-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.sa-pct { font-family: var(--mono); font-size: 0.85rem; color: var(--text); font-weight: 600; }
.sa-bar-track { flex: 1; height: 5px; background: var(--bg3); border-radius: 3px; }
.sa-bar-fill { height: 100%; border-radius: 3px; transition: width 0.8s ease; }
.sa-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
.sa-tag {
  font-family: var(--mono);
  font-size: 0.65rem;
  padding: 3px 10px;
  border-radius: 4px;
  letter-spacing: 0.05em;
}
.sa-tag.hit { background: rgba(78,203,113,0.15); color: var(--accent3); border: 1px solid rgba(78,203,113,0.2); }
.sa-tag.miss { background: rgba(255,255,255,0.05); color: var(--text3); border: 1px solid var(--border); }
.sa-model-toggle {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--text3);
